<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <TextView
        android:id="@+id/tvBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الرصيد: $0.00"
        android:textSize="20sp"
        android:textColor="#0078D7"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:padding="15dp"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/etPhoneNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvBalance"
        android:layout_margin="20dp"
        android:hint="أدخل الرقم"
        android:textSize="28sp"
        android:textAlignment="center"
        android:inputType="phone"
        android:background="@drawable/rounded_edittext"
        android:padding="20dp"
        android:textColor="#0078D7"
        android:textStyle="bold"/>

    <GridLayout
        android:id="@+id/keypad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:columnCount="3"
        android:alignmentMode="alignMargins"
        android:padding="10dp">

        <Button android:text="1" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="2" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="3" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="4" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="5" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="6" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="7" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="8" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="9" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="*" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="0" android:onClick="onDialClick" style="@style/KeypadButton"/>
        <Button android:text="#" android:onClick="onDialClick" style="@style/KeypadButton"/>
    </GridLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/keypad"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnCall"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_call"
            android:background="@drawable/circle_button"
            android:backgroundTint="#0078D7"
            android:tint="#FFFFFF"
            android:scaleType="center"
            android:layout_margin="15dp"/>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_input_delete"
            android:background="@drawable/circle_button"
            android:backgroundTint="#A80000"
            android:tint="#FFFFFF"
            android:scaleType="center"
            android:layout_margin="15dp"/>
    </LinearLayout>
</RelativeLayout>
