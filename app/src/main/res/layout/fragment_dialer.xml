<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_color">

    <!-- منطقة عرض الرقم -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="20dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="32sp"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold"
            android:gravity="center"
            android:hint="أدخل الرقم"
            android:textColorHint="#CCCCCC"/>
    </LinearLayout>

    <!-- لوحة المفاتيح -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="3"
        android:alignmentMode="alignMargins"
        android:padding="20dp">

        <!-- تم إضافة الخصائص layout_width و layout_columnWeight هنا مباشرة -->
        
        <Button android:text="1" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="2" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="3" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="4" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="5" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="6" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="7" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="8" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="9" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="*" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="0" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
        
        <Button android:text="#" android:onClick="onDialClick"
            android:layout_width="0dp" android:layout_height="70dp" android:layout_columnWeight="1" android:layout_margin="8dp"
            style="@style/KeypadButton"/>
    </GridLayout>

    <!-- أزرار الإجراءات -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="20dp"
        android:orientation="horizontal">

        <ImageButton
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_circle"
            android:src="@android:drawable/ic_menu_add"
            android:tint="@color/colorPrimary"/>

        <ImageButton
            android:id="@+id/btnCall"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_margin="15dp"
            android:background="@drawable/bg_key_circle"
            android:backgroundTint="@color/colorPrimary"
            android:src="@android:drawable/ic_menu_call"
            android:tint="@color/white"/>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_circle"
            android:src="@android:drawable/ic_input_delete"
            android:tint="@color/red"/>
    </LinearLayout>
</LinearLayout>
