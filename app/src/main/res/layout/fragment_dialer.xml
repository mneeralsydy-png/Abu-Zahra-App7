<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_color">

    <!-- منطقة عرض الرقم -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="20dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="32sp"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold"
            android:gravity="center"
            android:hint="أدخل الرقم"
            android:textColorHint="#CCCCCC"/>

        <!-- أزرار التبديل (Toggles) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="15dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="20dp">
                <TextView android:text="تسجيل" android:textSize="12sp" android:textColor="#666"/>
                <Switch android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView android:text="إخفاء الرقم" android:textSize="12sp" android:textColor="#666"/>
                <Switch android:id="@+id/switchHideId" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- لوحة المفاتيح -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="3"
        android:alignmentMode="alignMargins"
        android:padding="20dp">

        <Button android:text="1" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="2" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="3" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="4" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="5" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="6" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="7" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="8" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="9" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="*" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="0" style="@style/KeypadButton" android:onClick="onDialClick"/>
        <Button android:text="#" style="@style/KeypadButton" android:onClick="onDialClick"/>
    </GridLayout>

    <!-- أزرار الإجراءات -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="20dp"
        android:orientation="horizontal">

        <ImageButton
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_circle"
            android:src="@android:drawable/ic_menu_add"
            android:tint="@color/colorPrimary"/>

        <ImageButton
            android:id="@+id/btnCall"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_margin="15dp"
            android:background="@drawable/bg_key_circle"
            android:backgroundTint="@color/colorPrimary"
            android:src="@android:drawable/ic_menu_call"
            android:tint="@color/white"/>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_key_circle"
            android:src="@android:drawable/ic_input_delete"
            android:tint="@color/red"/>
    </LinearLayout>
</LinearLayout>
